# Display name for the bot — shown in the dashboard title and startup log
BOT_NAME=WhatsApp Moderator

# Path to your bot config file (default: ./bot.config.json)
# BOT_CONFIG=./bot.config.json

# Storage mode: 'filesystem' (default) or 'database'
# Filesystem mode requires no database — alerts and spam removal only.
# Database mode enables persistent activity tracking.
STORAGE_MODE=filesystem

# Directory for filesystem storage (STORAGE_MODE=filesystem only)
DATA_DIR=./data

# PostgreSQL connection string (STORAGE_MODE=database only)
# DATABASE_URL=postgresql://user:password@localhost:5432/littrbot

# WhatsApp session directory
AUTH_DIR=./auth

# Comma-separated phone numbers (no + or spaces) that receive spam/ban notifications
NUMBERS_TO_NOTIFY=447700000001,447700000002

# Comma-separated phone numbers that are exempt from spam scoring
ADMIN_NUMBERS=447700000001

# Score at or below which a user is removed from all groups in the network (-1 = disabled)
BAN_THRESHOLD=-1

# Points awarded per clean message
POINTS_PER_MSG=1

# Maximum score a user can accumulate
POINTS_MAX=100

